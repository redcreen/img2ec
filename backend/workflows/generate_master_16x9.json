    },
    "class_type": "DualCLIPLoader",
    "_meta": {
      "title": "Load Dual CLIP"
    }
  },
  "3": {
    "inputs": {
      "clip": [
        "2",
        0
      ],
      "clip_l": "__PROMPT__",
      "t5xxl": "__PROMPT__",
      "guidance": 3.5
    },
    "class_type": "CLIPTextEncodeFlux",
    "_meta": {
      "title": "Positive Prompt"
    }
  },
  "4": {
    "inputs": {
      "clip": [
        "2",
        0
      ],
      "clip_l": "__NEG__",
      "t5xxl": "__NEG__",
      "guidance": 3.5
    },
    "class_type": "CLIPTextEncodeFlux",
    "_meta": {
      "title": "Negative Prompt"
    }
  },
  "8": {
    "inputs": {
      "width": 3840,
      "height": 2160,
      "batch_size": 1
    },
    "class_type": "EmptyFlux2LatentImage",
    "_meta": {
      "title": "Empty Latent (3840×2160)"
    }
  },
  "9": {
    "inputs": {
      "vae_name": "taef1"
    },
    "class_type": "VAELoader",
    "_meta": {
      "title": "Load VAE"
    }
  },
  "10": {
    "inputs": {
      "model": [
        "1",
        0
      ],
      "positive": [
        "3",
        0
      ],
      "negative": [
        "4",
        0
      ],
      "latent_image": [
        "8",
        0
      ],
      "seed": "__SEED__",
      "steps": 28,
      "cfg": 1.0,
      "sampler_name": "dpmpp_2m_sde",
      "scheduler": "karras",
      "denoise": 1.0
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "KSampler"
    }
  },
  "11": {
    "inputs": {
      "samples": [
        "10",
        0
      ],
      "vae": [
        "9",
        0
      ]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "12": {
    "inputs": {
      "images": [
        "11",
        0
      ],
      "filename_prefix": "img2ec_master_16x9"
    },
    "class_type": "SaveImage",
    "_meta": {
      "title": "Save Image (16x9)"
    }
  }
